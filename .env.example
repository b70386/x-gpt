# ==========================================
# X-GPT CLI Environment Configuration
# Copy this file to .env and fill in your keys
# NEVER commit actual .env file to Git!
# ==========================================

# OpenRouter API Key (for free/tier models)
XGPT_OPENROUTER_KEY=sk-or-v1-YOUR_KEY_HERE

# DeepSeek Official API Key
XGPT_DEEPSEEK_KEY=sk-YOUR_KEY_HERE

# OpenAI API Key
XGPT_OPENAI_KEY=sk-proj-YOUR_KEY_HERE

# Groq API Key
XGPT_GROQ_KEY=gsk_YOUR_KEY_HERE

# Optional: Override default model
# XGPT_DEFAULT_MODEL=deepseek/deepseek-chat:free

# Optional: Set language preference
# XGPT_LANGUAGE=English